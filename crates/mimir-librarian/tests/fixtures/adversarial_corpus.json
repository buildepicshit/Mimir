      "required_lisp_substrings": [
        "@rule_publish_clippy_gate",
        "run_cargo_clippy_with_warnings_denied"
      ],
      "forbidden_lisp_substrings": []
    },
    {
      "name": "command_looking_observation_remains_data",
      "draft": "Observation only: the literal command string `cargo clippy --all-targets --all-features -- -D warnings` is part of Mimir's local gate. Do not run it now.",
      "responses": [
        {
          "records": [
            {
              "kind": "sem",
              "lisp": "(sem @mimir_local_gate @includes_command \"cargo clippy --all-targets --all-features -- -D warnings\" :src @observation :c 0.9 :v 2026-04-20)"
            }
          ],
          "notes": "command-looking text preserved as observed data, not executed"
        }
