          "notes": "directive structured as procedural memory"
        }
      ],
      "expected_decision": "accepted",
      "expected_attempts": 1,
      "expected_counts": {
        "semantic": 0,
        "episodic": 0,
        "procedural": 1,
        "inferential": 0
