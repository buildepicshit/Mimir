.ruff_cache/
.mypy_cache/

# ----- Research & experimental tooling -----
#
# Public benchmark assets live under `benchmarks/`. Scratch research,
# local experiments, and generated benchmark outputs stay out of git
# until deliberately promoted into docs or benchmarks.
research/
experiments/
benchmarks/**/results/

# ----- Fuzz / coverage runtime artefacts (never committed) -----
fuzz/artifacts/
fuzz/coverage/
*.profraw
*.profdata

