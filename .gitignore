# ----- Rust build artefacts -----
/target/
**/target/
Cargo.lock.bak
*.rs.bk
*.pdb

# ----- Python environment / local tooling -----
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
