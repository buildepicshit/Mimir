def run_recovery(args: argparse.Namespace) -> int:
    scenarios = load_scenarios(args.scenarios_dir.resolve())
    if args.summary_results:
        if (
            args.list
            or args.scenario
            or args.init_results
            or args.prepare_envs
            or args.validate_envs
            or args.launch_plan
            or args.write_launch_contracts
            or args.validate_launch_contracts
            or args.execute_launch_contracts
            or args.validate_transcripts
            or args.score_results
        ):
            raise BenchError(
                "recovery --summary-results cannot be combined with --list, "
                "--scenario, --init-results, --prepare-envs, --validate-envs, "
                "--launch-plan, --write-launch-contracts, "
                "--validate-launch-contracts, --execute-launch-contracts, "
                "--validate-transcripts, or --score-results"
            )
        emit(
            recovery_summary_results_payload(scenarios, args.results_dir.resolve()),
            args.format,
        )
        return 0
    if args.list:
        if (
            args.scenario
            or args.init_results
            or args.prepare_envs
            or args.validate_envs
            or args.launch_plan
            or args.write_launch_contracts
            or args.validate_launch_contracts
            or args.execute_launch_contracts
            or args.validate_transcripts
            or args.score_results
        ):
            raise BenchError(
                "recovery --list cannot be combined with --scenario, "
                "--init-results, --prepare-envs, --validate-envs, --launch-plan, "
                "--write-launch-contracts, --validate-launch-contracts, "
                "--execute-launch-contracts, --validate-transcripts, or "
                "--score-results"
            )
        emit(recovery_list_payload(scenarios), args.format)
        return 0
    if not args.scenario:
        raise BenchError(
            "recovery requires --list, --scenario <id> --dry-run, "
            "--scenario <id> --init-results, --scenario <id> --prepare-envs, "
            "--scenario <id> --validate-envs, --scenario <id> --launch-plan, "
            "--scenario <id> --write-launch-contracts, --scenario <id> "
            "--validate-launch-contracts, --scenario <id> "
            "--execute-launch-contracts --approve-live-execution <id>, "
            "--scenario <id> --validate-transcripts, or --scenario <id> "
            "--score-results"
        )
    scenario = find_scenario(scenarios, args.scenario)
    results_root = args.results_dir.resolve()
    action_count = sum(
        1
        for flag in (
            args.init_results,
            args.prepare_envs,
            args.validate_envs,
            args.launch_plan,
            args.write_launch_contracts,
            args.validate_launch_contracts,
            args.execute_launch_contracts,
            args.validate_transcripts,
            args.score_results,
        )
        if flag
    )
    if action_count > 1:
        raise BenchError(
            "--init-results, --prepare-envs, --validate-envs, --launch-plan, "
            "--write-launch-contracts, --validate-launch-contracts, "
            "--execute-launch-contracts, --validate-transcripts, and "
            "--score-results are mutually exclusive"
        )
    if args.execute_launch_contracts:
        emit(
            recovery_execute_launch_contracts_payload(
                scenario,
                results_root,
                args.approve_live_execution,
            ),
            args.format,
        )
        return 0
    if args.score_results:
        emit(recovery_score_results_payload(scenario, results_root), args.format)
        return 0
    if args.validate_envs:
        emit(recovery_validate_envs_payload(scenario, results_root), args.format)
        return 0
    if args.launch_plan:
        emit(recovery_launch_plan_payload(scenario, results_root), args.format)
        return 0
    if args.write_launch_contracts:
        emit(
            recovery_write_launch_contracts_payload(scenario, results_root),
            args.format,
        )
        return 0
    if args.validate_launch_contracts:
        emit(
            recovery_validate_launch_contracts_payload(scenario, results_root),
            args.format,
        )
        return 0
    if args.validate_transcripts:
        emit(recovery_validate_transcripts_payload(scenario, results_root), args.format)
        return 0
    if args.prepare_envs:
        emit(recovery_prepare_envs_payload(scenario, results_root), args.format)
        return 0
    if args.init_results:
        emit(recovery_init_results_payload(scenario, results_root), args.format)
        return 0
    if not args.dry_run:
        raise BenchError(
            "pass --dry-run or choose a concrete action such as "
            "--execute-launch-contracts with --approve-live-execution <scenario-id>"
        )
    emit(recovery_dry_run_payload(scenario, results_root), args.format)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    subcommands = parser.add_subparsers(dest="command", required=True)
    recovery = subcommands.add_parser("recovery", help="Plan recovery benchmark runs")
    recovery.add_argument("--list", action="store_true", help="List structured scenarios")
    recovery.add_argument("--scenario", help="Scenario id to plan")
    recovery.add_argument("--dry-run", action="store_true", help="Render the plan only")
    recovery.add_argument(
        "--init-results",
        action="store_true",
        help="Create scorecard, transcript, notes, and run-plan skeletons",
    )
    recovery.add_argument(
        "--prepare-envs",
        action="store_true",
        help="Create per-baseline recovery environment scaffolds",
    )
    recovery.add_argument(
        "--validate-envs",
        action="store_true",
        help="Validate prepared baseline environment population inputs",
    )
    recovery.add_argument(
        "--launch-plan",
        action="store_true",
        help="Render non-executing per-baseline launch contracts",
    )
    recovery.add_argument(
        "--write-launch-contracts",
        action="store_true",
        help="Write non-executing launch contracts for fully ready baselines",
    )
    recovery.add_argument(
        "--validate-launch-contracts",
        action="store_true",
        help="Validate materialized launch contracts before execution",
    )
    recovery.add_argument(
        "--execute-launch-contracts",
        action="store_true",
        help="Execute validated launch contracts and capture transcripts",
    )
    recovery.add_argument(
        "--approve-live-execution",
        help="Required approval token for --execute-launch-contracts; use scenario id",
    )
    recovery.add_argument(
        "--validate-transcripts",
        action="store_true",
        help="Validate captured baseline transcript files before scoring",
    )
    recovery.add_argument(
        "--score-results",
        action="store_true",
        help="Validate and summarize a scenario scores.json file",
    )
    recovery.add_argument(
        "--summary-results",
        action="store_true",
        help="Summarize all scenario scores.json files under --results-dir",
    )
    recovery.add_argument(
        "--format",
        choices=("text", "json"),
        default="text",
        help="Output format",
    )
    recovery.add_argument(
        "--scenarios-dir",
        type=Path,
        default=DEFAULT_SCENARIOS_DIR,
        help="Directory containing scenario JSON files",
    )
    recovery.add_argument(
        "--results-dir",
        type=Path,
        default=RESULTS_ROOT,
        help="Directory where recovery result skeletons are written",
    )
    return parser


def main(argv: list[str]) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        if args.command == "recovery":
            return run_recovery(args)
    except BenchError as error:
        print(f"bench: {error}", file=sys.stderr)
        return 2
    parser.error(f"unknown command {args.command}")
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
