#!/usr/bin/env python3
"""Repository-local benchmark entry point.

Currently implemented:
  ./bench recovery --list
  ./bench recovery --scenario <id> --dry-run
  ./bench recovery --scenario <id> --init-results
  ./bench recovery --scenario <id> --prepare-envs
  ./bench recovery --scenario <id> --validate-envs
  ./bench recovery --scenario <id> --launch-plan
  ./bench recovery --scenario <id> --write-launch-contracts
  ./bench recovery --scenario <id> --validate-launch-contracts
  ./bench recovery --scenario <id> --execute-launch-contracts --approve-live-execution <id>
  ./bench recovery --scenario <id> --validate-transcripts
  ./bench recovery --scenario <id> --score-results
  ./bench recovery --summary-results

The recovery command is dry-run by default. Live baseline execution is
available only through validated launch contracts and an explicit
per-scenario approval token.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

REPO_ROOT = Path(__file__).resolve().parent
DEFAULT_SCENARIOS_DIR = REPO_ROOT / "benchmarks" / "recovery" / "scenarios"
RESULTS_ROOT = REPO_ROOT / "benchmarks" / "recovery" / "results"


class BenchError(Exception):
    """User-facing benchmark command error."""


def load_scenarios(scenarios_dir: Path) -> list[dict[str, Any]]:
    if not scenarios_dir.is_dir():
        raise BenchError(f"scenarios directory does not exist: {scenarios_dir}")
    scenarios: list[dict[str, Any]] = []
    for path in sorted(scenarios_dir.glob("*.json")):
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError as error:
            raise BenchError(f"{path}: invalid JSON: {error}") from error
        validate_scenario(data, path)
        scenario_id = require_text(data, "id", path)
        if path.stem != scenario_id:
            raise BenchError(f"{path}: id must match filename stem")
        scenarios.append(data)
    if not scenarios:
        raise BenchError(f"no scenario JSON files found in {scenarios_dir}")
    return scenarios


def validate_scenario(data: Any, path: Path) -> None:
    if not isinstance(data, dict):
        raise BenchError(f"{path}: scenario must be an object")
    if data.get("schema_version") != 1:
        raise BenchError(f"{path}: schema_version must be 1")
    for field in (
        "id",
        "status",
        "title",
        "source_markdown",
        "situation",
        "cold_start_prompt",
        "work_instruction_test",
    ):
        require_text(data, field, path)
    cutoff = data.get("cutoff_minutes")
    if isinstance(cutoff, bool) or not isinstance(cutoff, int) or cutoff <= 0:
        raise BenchError(f"{path}: cutoff_minutes must be a positive integer")

    baselines = require_list(data, "baselines", path, allow_empty=False)
    baseline_ids = [
        item.get("id") if isinstance(item, dict) else None for item in baselines
    ]
    if baseline_ids != ["A", "B", "C", "D"]:
        raise BenchError(f"{path}: baselines must be exactly A, B, C, D")
    for index, baseline in enumerate(baselines):
        label = f"baselines[{index}]"
        require_item_object(baseline, path, label)
        require_nested_text(baseline, "id", path, label)
        require_nested_text(baseline, "name", path, label)
        require_nested_text(baseline, "preserved_state", path, label)

    ground_truth = require_list(data, "ground_truth", path, allow_empty=False)
    ground_truth_ids = []
    for index, item in enumerate(ground_truth):
        label = f"ground_truth[{index}]"
        require_item_object(item, path, label)
        ground_truth_ids.append(require_nested_text(item, "id", path, label))
        require_nested_text(item, "category", path, label)
        require_nested_text(item, "text", path, label)
        require_string_list(item, "source_refs", path, label)
        if not isinstance(item.get("auto_fail_if_wrong"), bool):
            raise BenchError(f"{path}: {label}.auto_fail_if_wrong must be a boolean")
    require_unique_ids(ground_truth_ids, path, "ground_truth")

    staleness_tests = require_list(data, "staleness_tests", path, allow_empty=True)
    staleness_test_ids = []
    for index, item in enumerate(staleness_tests):
        label = f"staleness_tests[{index}]"
        require_item_object(item, path, label)
        staleness_test_ids.append(require_nested_text(item, "id", path, label))
        require_nested_text(item, "superseded_fact", path, label)
        require_nested_text(item, "current_fact", path, label)
        require_nested_text(item, "expected_behavior", path, label)
    require_unique_ids(staleness_test_ids, path, "staleness_tests")


def require_text(data: dict[str, Any], field: str, path: Path) -> str:
    value = data.get(field)
    if not isinstance(value, str) or not value.strip():
        raise BenchError(f"{path}: missing non-empty string field {field}")
    return value


def require_nested_text(
    data: dict[str, Any],
    field: str,
    path: Path,
    label: str,
) -> str:
    value = data.get(field)
    if not isinstance(value, str) or not value.strip():
        raise BenchError(f"{path}: {label}.{field} must be a non-empty string")
    return value


def require_list(
    data: dict[str, Any],
    field: str,
    path: Path,
    *,
    allow_empty: bool,
) -> list[Any]:
    value = data.get(field)
    if not isinstance(value, list) or (not allow_empty and not value):
        qualifier = "a list" if allow_empty else "a non-empty list"
        raise BenchError(f"{path}: {field} must be {qualifier}")
    return value


def require_item_object(value: Any, path: Path, label: str) -> dict[str, Any]:
    if not isinstance(value, dict):
        raise BenchError(f"{path}: {label} must be an object")
    return value


def require_string_list(
    data: dict[str, Any],
    field: str,
    path: Path,
    label: str,
) -> list[str]:
    value = data.get(field)
    if (
        not isinstance(value, list)
        or not value
        or any(not isinstance(item, str) or not item.strip() for item in value)
    ):
        raise BenchError(
            f"{path}: {label}.{field} must be a non-empty list of strings"
        )
    return value


def require_unique_ids(ids: list[str], path: Path, label: str) -> None:
    seen = set()
    duplicates = []
    for item_id in ids:
        if item_id in seen and item_id not in duplicates:
            duplicates.append(item_id)
        seen.add(item_id)
    if duplicates:
        raise BenchError(
            f"{path}: {label} ids must be unique: {', '.join(duplicates)}"
        )


def scenario_summary(scenario: dict[str, Any]) -> dict[str, Any]:
    return {
        "id": scenario["id"],
        "title": scenario["title"],
        "status": scenario["status"],
        "ground_truth_count": len(scenario["ground_truth"]),
        "staleness_test_count": len(scenario["staleness_tests"]),
    }


def find_scenario(scenarios: list[dict[str, Any]], scenario_id: str) -> dict[str, Any]:
    for scenario in scenarios:
        if scenario["id"] == scenario_id:
            return scenario
    known = ", ".join(scenario["id"] for scenario in scenarios)
    raise BenchError(f"unknown scenario {scenario_id}; known scenarios: {known}")


def recovery_list_payload(scenarios: list[dict[str, Any]]) -> dict[str, Any]:
    return {
        "mode": "list",
        "scenarios": [scenario_summary(scenario) for scenario in scenarios],
    }


def recovery_dry_run_payload(
    scenario: dict[str, Any],
    results_root: Path = RESULTS_ROOT,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    baselines = []
    expected_artifacts = []
    for baseline in scenario["baselines"]:
        baseline_id = baseline["id"]
        transcript = result_dir / f"transcript-{baseline_id}.md"
        baselines.append(
            {
                "id": baseline_id,
                "name": baseline["name"],
                "preserved_state": baseline["preserved_state"],
                "transcript_path": display_path(transcript),
            }
        )
        expected_artifacts.append(display_path(transcript))
    expected_artifacts.extend(
        [
            display_path(result_dir / "scorecard.md"),
            display_path(result_dir / "scores.json"),
            display_path(result_dir / "notes.md"),
            display_path(result_dir / "run-plan.json"),
        ]
    )

    load_bearing = [
        item
        for item in scenario["ground_truth"]
        if item["category"] == "load_bearing_decision"
    ]
    return {
        "mode": "dry_run",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "status": scenario["status"],
        "cutoff_minutes": scenario["cutoff_minutes"],
        "cold_start_prompt": scenario["cold_start_prompt"],
        "work_instruction_test": scenario["work_instruction_test"],
        "ground_truth_count": len(scenario["ground_truth"]),
        "load_bearing_decision_count": len(load_bearing),
        "staleness_test_count": len(scenario["staleness_tests"]),
        "baselines": baselines,
        "expected_artifacts": expected_artifacts,
        "next_action": (
            "Create isolated baseline environments and capture transcripts; "
            "use validated launch contracts plus explicit approval for live execution."
        ),
    }


def recovery_init_results_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    files = recovery_result_files(scenario, result_dir, results_root)
    created = []
    skipped = []
    for path, content in files:
        if path.exists():
            if not path.is_file():
                raise BenchError(f"artifact path exists and is not a file: {path}")
            skipped.append(display_path(path))
            continue
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")
        created.append(display_path(path))

    return {
        "mode": "init_results",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "status": scenario["status"],
        "result_dir": display_path(result_dir),
        "created_count": len(created),
        "skipped_count": len(skipped),
        "created_artifacts": created,
        "skipped_artifacts": skipped,
        "next_action": (
            "Run each baseline manually, replace transcript placeholders, "
            "then fill scorecard.md."
        ),
    }


def recovery_result_files(
    scenario: dict[str, Any],
    result_dir: Path,
    results_root: Path,
) -> list[tuple[Path, str]]:
    files: list[tuple[Path, str]] = []
    for baseline in scenario["baselines"]:
        files.append(
            (
                result_dir / f"transcript-{baseline['id']}.md",
                transcript_template(scenario, baseline),
            )
        )
    files.extend(
        [
            (result_dir / "scorecard.md", scorecard_template(scenario)),
            (result_dir / "scores.json", scores_template(scenario)),
            (result_dir / "notes.md", notes_template(scenario)),
            (
                result_dir / "run-plan.json",
                json.dumps(
                    recovery_dry_run_payload(scenario, results_root),
                    indent=2,
                    sort_keys=True,
                )
                + "\n",
            ),
        ]
    )
    return files


def recovery_validate_transcripts_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    rows = []
    for baseline in scenario["baselines"]:
        baseline_id = baseline["id"]
        transcript_path = result_dir / f"transcript-{baseline_id}.md"
        captured, problem = transcript_capture_status(transcript_path, scenario)
        rows.append(
            {
                "baseline_id": baseline_id,
                "baseline_name": baseline["name"],
                "transcript_path": display_path(transcript_path),
                "captured": captured,
                "problem": problem,
            }
        )
    captured_count = sum(1 for row in rows if row["captured"])
    placeholder_count = sum(1 for row in rows if row["problem"] == "placeholder")
    missing_count = sum(1 for row in rows if row["problem"] == "missing")
    return {
        "mode": "validate_transcripts",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "ready_for_scoring": captured_count == len(rows),
        "captured_count": captured_count,
        "placeholder_count": placeholder_count,
        "missing_count": missing_count,
        "baselines": rows,
    }


def transcript_capture_status(
    path: Path,
    scenario: dict[str, Any],
) -> tuple[bool, str | None]:
    if not path.exists():
        return False, "missing"
    if not path.is_file():
        return False, "not_file"
    text = path.read_text(encoding="utf-8")
    if not text.strip():
        return False, "empty"
    if "<paste full agent transcript here>" in text:
        return False, "placeholder"
    if (
        scenario["cold_start_prompt"] not in text
        or scenario["work_instruction_test"] not in text
    ):
        return False, "missing_prompt_evidence"
    return True, None


def recovery_prepare_envs_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    files = recovery_environment_files(scenario, result_dir)
    created = []
    skipped = []
    for path, content in files:
        if path.exists():
            if not path.is_file():
                raise BenchError(f"environment path exists and is not a file: {path}")
            skipped.append(display_path(path))
            continue
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")
        created.append(display_path(path))
    return {
        "mode": "prepare_envs",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "environment_root": display_path(result_dir / "environments"),
        "created_count": len(created),
        "skipped_count": len(skipped),
        "created_artifacts": created,
        "skipped_artifacts": skipped,
        "next_action": (
            "Populate preserved-state directories and launch baselines manually; "
            "or validate launch contracts and use explicit live execution."
        ),
    }


def recovery_environment_files(
    scenario: dict[str, Any],
    result_dir: Path,
) -> list[tuple[Path, str]]:
    files: list[tuple[Path, str]] = []
    for baseline in scenario["baselines"]:
        env_dir = result_dir / "environments" / baseline["id"]
        files.extend(
            [
                (
                    env_dir / "manifest.json",
                    environment_manifest(scenario, baseline, result_dir),
                ),
                (
                    env_dir / "cold-start-prompt.txt",
                    scenario["cold_start_prompt"] + "\n",
                ),
                (
                    env_dir / "work-instruction-test.txt",
                    scenario["work_instruction_test"] + "\n",
                ),
                (env_dir / "preserved-state.md", preserved_state_template(baseline)),
                (
                    env_dir / "materialized-inputs.json",
                    materialized_inputs_template(scenario, baseline),
                ),
                (env_dir / "README.md", environment_readme(scenario, baseline)),
            ]
        )
    return files


def environment_manifest(
    scenario: dict[str, Any],
    baseline: dict[str, Any],
    result_dir: Path,
) -> str:
    baseline_id = baseline["id"]
    payload = {
        "schema_version": 1,
        "mode": "environment_scaffold",
        "live_execution": False,
        "scenario_id": scenario["id"],
        "scenario_title": scenario["title"],
        "scenario_status": scenario["status"],
        "baseline_id": baseline_id,
        "baseline_name": baseline["name"],
        "preserved_state": baseline["preserved_state"],
        "cold_start_prompt_path": display_path(
            result_dir / "environments" / baseline_id / "cold-start-prompt.txt"
        ),
        "work_instruction_test_path": display_path(
            result_dir / "environments" / baseline_id / "work-instruction-test.txt"
        ),
        "preserved_state_path": display_path(
            result_dir / "environments" / baseline_id / "preserved-state.md"
        ),
        "materialized_inputs_path": display_path(
            result_dir / "environments" / baseline_id / "materialized-inputs.json"
        ),
        "transcript_path": display_path(result_dir / f"transcript-{baseline_id}.md"),
    }
    return json.dumps(payload, indent=2, sort_keys=True) + "\n"


def preserved_state_template(baseline: dict[str, Any]) -> str:
    return "\n".join(
        [
            f"# Baseline {baseline['id']} - preserved state",
            "",
            baseline["preserved_state"],
            "",
            "## Materialized Inputs",
            "",
            "<record exact files, directories, logs, or handoff docs copied here>",
            "",
        ]
    )


def environment_readme(scenario: dict[str, Any], baseline: dict[str, Any]) -> str:
    return "\n".join(
        [
            f"# Scenario {scenario['id']} - baseline {baseline['id']}",
            "",
            f"Scenario: {scenario['title']}",
            f"Baseline: {baseline['name']}",
            "",
            "This directory is a deterministic scaffold for one recovery baseline.",
            "It does not launch an agent or prove recovery by itself.",
            "",
            "## Files",
            "",
            "- `manifest.json` - machine-readable environment scaffold.",
            "- `cold-start-prompt.txt` - prompt to issue to the agent.",
            "- `work-instruction-test.txt` - productive-state gate.",
            "- `preserved-state.md` - preserved-state setup notes.",
            "- `materialized-inputs.json` - required preserved-state inputs.",
            "",
            "## Transcript Target",
            "",
            f"Write the captured transcript to `../../transcript-{baseline['id']}.md`.",
            "",
        ]
    )


def materialized_inputs_template(
    scenario: dict[str, Any],
    baseline: dict[str, Any],
) -> str:
    return (
        json.dumps(
            {
                "schema_version": 1,
                "scenario_id": scenario["id"],
                "baseline_id": baseline["id"],
                "baseline_name": baseline["name"],
                "inputs": baseline_required_inputs(baseline),
            },
            indent=2,
            sort_keys=True,
        )
        + "\n"
    )


def baseline_required_inputs(baseline: dict[str, Any]) -> list[dict[str, Any]]:
    baseline_id = baseline["id"]
    if baseline_id == "A":
        return []
    if baseline_id == "B":
        return [
            {
                "id": "claude_markdown_memory_dir",
                "kind": "directory",
                "required": True,
                "description": "Preserved Claude auto-memory markdown directory for this scenario.",
                "path": None,
                "verified": False,
            }
        ]
    if baseline_id == "C":
        return [
            {
                "id": "curated_handoff_doc",
                "kind": "file",
                "required": True,
                "description": "Operator-written STATUS-style handoff document for this scenario.",
                "path": None,
                "verified": False,
            }
        ]
    if baseline_id == "D":
        return [
            {
                "id": "canonical_mimir_log",
                "kind": "file",
                "required": True,
                "description": "Canonical Mimir log or restored recovery mirror for this scenario.",
                "path": None,
                "verified": False,
            }
        ]
    return [
        {
            "id": "baseline_preserved_state",
            "kind": "manual",
            "required": True,
            "description": baseline["preserved_state"],
            "path": None,
            "verified": False,
        }
    ]


