def scorecard_template(scenario: dict[str, Any]) -> str:
    load_bearing_count = sum(
        1
        for item in scenario["ground_truth"]
        if item["category"] == "load_bearing_decision"
    )
    lines = [
        f"# Scenario {scenario['id']} - scorecard",
        "",
        f"Scenario: {scenario['title']}",
        f"Status: {scenario['status']}",
        f"Cutoff: {scenario['cutoff_minutes']} minutes",
        f"Ground truth items: {len(scenario['ground_truth'])}",
        f"Load-bearing decisions: {load_bearing_count}",
        f"Staleness tests: {len(scenario['staleness_tests'])}",
        "Run date: <YYYY-MM-DD>",
        "Operator: <name>",
        "",
        "## Prompts",
        "",
        f"Cold-start prompt: {scenario['cold_start_prompt']}",
        f"Work-instruction test: {scenario['work_instruction_test']}",
        "",
        "## Ground Truth Checklist",
        "",
        "| ID | Category | Auto-fail if wrong | Expected fact | Rating | Notes |",
        "|---|---|---:|---|---|---|",
    ]
    for item in scenario["ground_truth"]:
        auto_fail = "yes" if item.get("auto_fail_if_wrong") else "no"
        lines.append(
            "| "
            + " | ".join(
                [
                    markdown_cell(item["id"]),
                    markdown_cell(item["category"]),
                    auto_fail,
                    markdown_cell(item["text"]),
                    "<C|P|W|S>",
                    "",
                ]
            )
            + " |"
        )
    lines.extend(
        [
            "",
            "## Staleness Checks",
            "",
            "| ID | Superseded fact | Current fact | Expected behavior | Result | Notes |",
            "|---|---|---|---|---|---|",
        ]
    )
    for item in scenario["staleness_tests"]:
        lines.append(
            "| "
            + " | ".join(
                [
                    markdown_cell(item["id"]),
                    markdown_cell(item["superseded_fact"]),
                    markdown_cell(item["current_fact"]),
                    markdown_cell(item["expected_behavior"]),
                    "<Fresh|Stale|Qualified|Silent>",
                    "",
                ]
            )
            + " |"
        )
    for baseline in scenario["baselines"]:
        lines.extend(
            [
                "",
                f"## Baseline {baseline['id']} - {baseline['name']}",
                "",
                f"Preserved state: {baseline['preserved_state']}",
                "",
                "- Time to productive state: <N minutes | DNR>",
                (
                    "- Fact correctness: C <N> / P <N> / W <N> / S <N> "
                    "- <C %> unprompted-correct"
                ),
                "- Hallucinations: <N> out of <M> decision-assertions",
                "- Staleness: <N stale occurrences>",
                "- Rehydration tokens: input <N>, output <N>",
                "- Transcript: "
                f"transcript-{baseline['id']}.md",
            ]
        )
    lines.extend(
        [
            "",
            "## Operator Commentary",
            "",
            "<What surprised. Where the signal was strongest. Gaps Mimir revealed in itself.>",
            "",
        ]
    )
    return "\n".join(lines)


def scores_template(scenario: dict[str, Any]) -> str:
    baselines: dict[str, Any] = {}
    for baseline in scenario["baselines"]:
        baselines[baseline["id"]] = {
            "time_to_productive_minutes": None,
            "fact_correctness": {
                "correct": None,
                "prompted": None,
                "wrong": None,
                "silent": None,
            },
            "decision_assertions": {
                "hallucinations": None,
                "total": None,
            },
            "staleness": {
                "stale_occurrences": None,
            },
            "rehydration_tokens": {
                "input": None,
                "output": None,
            },
        }
    return (
        json.dumps(
            {
                "schema_version": 1,
                "scenario_id": scenario["id"],
                "baselines": baselines,
            },
            indent=2,
            sort_keys=True,
        )
        + "\n"
    )


