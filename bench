def markdown_cell(value: Any) -> str:
    return str(value).replace("\n", " ").replace("|", "\\|")


def display_path(path: Path) -> str:
    resolved = path.resolve()
    try:
        return resolved.relative_to(REPO_ROOT).as_posix()
    except ValueError:
        return str(resolved)


def recovery_score_results_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    scores_path = result_dir / "scores.json"
    if not scores_path.is_file():
        raise BenchError(
            f"scores file does not exist: {scores_path}; run --init-results"
        )
    try:
        scores = json.loads(scores_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise BenchError(f"{scores_path}: invalid JSON: {error}") from error
    missing_fields, summaries = validate_scores(scenario, scores, scores_path)
    transcript_validation = recovery_validate_transcripts_payload(scenario, results_root)
    transcript_problems = transcript_problem_rows(transcript_validation)
    complete = not missing_fields and not transcript_problems
    return {
        "mode": "score_results",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "score_path": display_path(scores_path),
        "complete": complete,
        "missing_count": len(missing_fields),
        "missing_fields": missing_fields,
        "transcripts_ready": transcript_validation["ready_for_scoring"],
        "transcript_problem_count": len(transcript_problems),
        "transcript_problems": transcript_problems,
        "baseline_summaries": summaries if complete else [],
    }


def recovery_validate_envs_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    rows = []
    for baseline in scenario["baselines"]:
        baseline_id = baseline["id"]
        env_dir = result_dir / "environments" / baseline_id
        manifest_path = env_dir / "manifest.json"
        inputs_path = env_dir / "materialized-inputs.json"
        missing_files = []
        for path in (
            manifest_path,
            env_dir / "cold-start-prompt.txt",
            env_dir / "work-instruction-test.txt",
            env_dir / "preserved-state.md",
            inputs_path,
            env_dir / "README.md",
        ):
            if not path.is_file():
                missing_files.append(display_path(path))

        missing_inputs: list[str] = []
        invalid_inputs: list[dict[str, str]] = []
        if inputs_path.is_file():
            inputs = load_materialized_inputs(inputs_path, scenario_id, baseline_id)
            expected_required_ids = [
                item["id"]
                for item in baseline_required_inputs(baseline)
                if item.get("required")
            ]
            actual_input_ids = {item["id"] for item in inputs["inputs"]}
            for required_id in expected_required_ids:
                if required_id not in actual_input_ids:
                    missing_inputs.append(required_id)
            for item in inputs["inputs"]:
                if item.get("required") and (
                    not item.get("path") or item.get("verified") is not True
                ):
                    missing_inputs.append(item["id"])
                elif item.get("required"):
                    problem = materialized_input_path_problem(item)
                    if problem is not None:
                        invalid_inputs.append(
                            {
                                "id": item["id"],
                                "path": str(item.get("path")),
                                "problem": problem,
                            }
                        )
        elif not missing_files:
            missing_inputs.append("materialized_inputs")

        ready = not missing_files and not missing_inputs and not invalid_inputs
        rows.append(
            {
                "baseline_id": baseline_id,
                "baseline_name": baseline["name"],
                "ready_for_launch": ready,
                "environment_dir": display_path(env_dir),
                "missing_files": missing_files,
                "missing_inputs": missing_inputs,
                "invalid_inputs": invalid_inputs,
            }
        )
    ready_count = sum(1 for row in rows if row["ready_for_launch"])
    return {
        "mode": "validate_envs",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "ready_count": ready_count,
        "blocked_count": len(rows) - ready_count,
        "baselines": rows,
    }


def recovery_launch_plan_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    validation = recovery_validate_envs_payload(scenario, results_root)
    rows = []
    for baseline, validation_row in zip(
        scenario["baselines"],
        validation["baselines"],
        strict=True,
    ):
        baseline_id = baseline["id"]
        blocked_reasons = launch_blocked_reasons(validation_row)
        rows.append(
            {
                "baseline_id": baseline_id,
                "baseline_name": baseline["name"],
                "ready_for_launch": validation_row["ready_for_launch"],
                "blocked_reasons": blocked_reasons,
                "launch_contract": launch_contract(scenario, baseline, result_dir)
                if validation_row["ready_for_launch"]
                else None,
            }
        )
    launchable_count = sum(1 for row in rows if row["ready_for_launch"])
    return {
        "mode": "launch_plan",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "ready_to_launch": launchable_count == len(rows),
        "launchable_count": launchable_count,
        "blocked_count": len(rows) - launchable_count,
        "baselines": rows,
        "next_action": (
            "Review launch contracts, then write and validate them; "
            "this command does not launch agents."
        ),
    }


def recovery_write_launch_contracts_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    launch_plan = recovery_launch_plan_payload(scenario, results_root)
    rows = []
    created = []
    skipped = []
    if not launch_plan["ready_to_launch"]:
        for row in launch_plan["baselines"]:
            baseline_id = row["baseline_id"]
            rows.append(
                {
                    "baseline_id": baseline_id,
                    "baseline_name": row["baseline_name"],
                    "ready_for_launch": row["ready_for_launch"],
                    "blocked_reasons": row["blocked_reasons"],
                    "launch_contract_path": display_path(
                        result_dir
                        / "environments"
                        / baseline_id
                        / "launch-contract.json"
                    ),
                    "written": False,
                    "skipped": False,
                }
            )
        return {
            "mode": "write_launch_contracts",
            "live_execution": False,
            "scenario_id": scenario_id,
            "title": scenario["title"],
            "ready_to_launch": False,
            "created_count": 0,
            "skipped_count": 0,
            "blocked_count": launch_plan["blocked_count"],
            "created_artifacts": [],
            "skipped_artifacts": [],
            "baselines": rows,
            "next_action": (
                "Populate all baseline environments before writing launch contracts."
            ),
        }

    for row in launch_plan["baselines"]:
        baseline_id = row["baseline_id"]
        contract_path = (
            result_dir / "environments" / baseline_id / "launch-contract.json"
        )
        if contract_path.exists():
            if not contract_path.is_file():
                raise BenchError(
                    f"launch contract path exists and is not a file: {contract_path}"
                )
            skipped.append(display_path(contract_path))
            written = False
            was_skipped = True
        else:
            contract_path.parent.mkdir(parents=True, exist_ok=True)
            contract_path.write_text(
                json.dumps(row["launch_contract"], indent=2, sort_keys=True) + "\n",
                encoding="utf-8",
            )
            created.append(display_path(contract_path))
            written = True
            was_skipped = False
        rows.append(
            {
                "baseline_id": baseline_id,
                "baseline_name": row["baseline_name"],
                "ready_for_launch": True,
                "blocked_reasons": [],
                "launch_contract_path": display_path(contract_path),
                "written": written,
                "skipped": was_skipped,
            }
        )

    return {
        "mode": "write_launch_contracts",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "ready_to_launch": True,
        "created_count": len(created),
        "skipped_count": len(skipped),
        "blocked_count": 0,
        "created_artifacts": created,
        "skipped_artifacts": skipped,
        "baselines": rows,
        "next_action": (
            "Launch each baseline from its materialized contract and capture transcripts."
        ),
    }


def recovery_validate_launch_contracts_payload(
    scenario: dict[str, Any],
    results_root: Path,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    result_dir = results_root / scenario_id
    launch_plan = recovery_launch_plan_payload(scenario, results_root)
    rows = []
    for row in launch_plan["baselines"]:
        baseline_id = row["baseline_id"]
        contract_path = (
            result_dir / "environments" / baseline_id / "launch-contract.json"
        )
        problem = launch_contract_problem(contract_path, row, scenario)
        rows.append(
            {
                "baseline_id": baseline_id,
                "baseline_name": row["baseline_name"],
                "ready_for_launch": row["ready_for_launch"],
                "launch_contract_path": display_path(contract_path),
                "valid": problem is None,
                "problem": problem,
            }
        )
    valid_count = sum(1 for row in rows if row["valid"])
    problem_count = len(rows) - valid_count
    return {
        "mode": "validate_launch_contracts",
        "live_execution": False,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "ready_for_execution": launch_plan["ready_to_launch"] and problem_count == 0,
        "valid_count": valid_count,
        "problem_count": problem_count,
        "missing_count": sum(1 for row in rows if row["problem"] == "missing"),
        "baselines": rows,
    }


def recovery_execute_launch_contracts_payload(
    scenario: dict[str, Any],
    results_root: Path,
    approval: str | None,
) -> dict[str, Any]:
    scenario_id = scenario["id"]
    if approval != scenario_id:
        raise BenchError(
            "--execute-launch-contracts requires --approve-live-execution "
            f"{scenario_id}"
        )

    result_dir = results_root / scenario_id
    run_summary_path = result_dir / "live-run.json"
    if run_summary_path.exists():
        raise BenchError(
            f"refusing to overwrite live execution summary: {run_summary_path}"
        )

    validation = recovery_validate_launch_contracts_payload(scenario, results_root)
    if not validation["ready_for_execution"]:
        raise BenchError(
            "launch contracts are not ready for execution; run "
            "--validate-launch-contracts and fix reported problems"
        )

    launch_plan = recovery_launch_plan_payload(scenario, results_root)
    scores_path = result_dir / "scores.json"
    scores = load_scores_for_mechanical_update(scenario, scores_path)
    rows = []
    mechanical_updates = 0
    for row in launch_plan["baselines"]:
        contract = row["launch_contract"]
        if contract is None:
            raise BenchError(
                f"baseline {row['baseline_id']} has no launch contract"
            )
        transcript_path = resolve_contract_path(contract["transcript_path"])
        ensure_transcript_can_be_written(transcript_path, scenario)
        execution = execute_launch_contract(contract)
        transcript_path.parent.mkdir(parents=True, exist_ok=True)
        transcript_path.write_text(
            execution_transcript(scenario, row, contract, execution),
            encoding="utf-8",
        )
        mechanical_updates += update_mechanical_scores(
            scores,
            row["baseline_id"],
            scenario,
            execution,
        )
        rows.append(
            {
                "baseline_id": row["baseline_id"],
                "baseline_name": row["baseline_name"],
                "runner": contract["runner"],
                "argv": contract["argv"],
                "transcript_path": display_path(transcript_path),
                "exit_code": execution["exit_code"],
                "timed_out": execution["timed_out"],
                "duration_seconds": execution["duration_seconds"],
                "success": execution["success"],
            }
        )

    scores_path.write_text(
        json.dumps(scores, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )
    transcript_validation = recovery_validate_transcripts_payload(scenario, results_root)
    run_summary = {
        "schema_version": 1,
        "mode": "execute_launch_contracts",
        "live_execution": True,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "results_root": display_path(results_root),
        "score_path": display_path(scores_path),
        "mechanical_scores_updated_count": mechanical_updates,
        "transcripts_ready": transcript_validation["ready_for_scoring"],
        "baselines": rows,
    }
    run_summary_path.parent.mkdir(parents=True, exist_ok=True)
    run_summary_path.write_text(
        json.dumps(run_summary, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )

    failed = [row for row in rows if not row["success"]]
    if failed:
        failed_ids = ", ".join(row["baseline_id"] for row in failed)
        raise BenchError(f"live execution failed for baseline(s): {failed_ids}")
    if not transcript_validation["ready_for_scoring"]:
        problems = ", ".join(
            f"{row['baseline_id']}={row['problem']}"
            for row in transcript_validation["baselines"]
            if not row["captured"]
        )
        raise BenchError(f"captured transcripts failed evidence validation: {problems}")

    return {
        "mode": "execute_launch_contracts",
        "live_execution": True,
        "scenario_id": scenario_id,
        "title": scenario["title"],
        "run_summary_path": display_path(run_summary_path),
        "executed_count": len(rows),
        "failed_count": len(failed),
        "mechanical_scores_updated_count": mechanical_updates,
        "transcripts_ready": transcript_validation["ready_for_scoring"],
        "baselines": rows,
        "next_action": (
            "Operator fills nuanced score fields in scores.json, then runs "
            "--score-results."
        ),
    }


def load_scores_for_mechanical_update(
    scenario: dict[str, Any],
    scores_path: Path,
) -> dict[str, Any]:
    if not scores_path.is_file():
        raise BenchError(
            f"scores file does not exist: {scores_path}; run --init-results"
        )
    try:
        scores = json.loads(scores_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise BenchError(f"{scores_path}: invalid JSON: {error}") from error
    require_mapping(scores, scores_path, "root")
    if scores.get("schema_version") != 1:
        raise BenchError(f"{scores_path}: schema_version must be 1")
    if scores.get("scenario_id") != scenario["id"]:
        raise BenchError(f"{scores_path}: scenario_id must match {scenario['id']}")
    require_mapping(scores.get("baselines"), scores_path, "baselines")
    return scores


def ensure_transcript_can_be_written(
    transcript_path: Path,
    scenario: dict[str, Any],
) -> None:
    captured, problem = transcript_capture_status(transcript_path, scenario)
    if captured or problem in {"missing_prompt_evidence", "not_file"}:
        raise BenchError(
            f"refusing to overwrite captured transcript: {transcript_path}"
        )


def execute_launch_contract(contract: dict[str, Any]) -> dict[str, Any]:
    argv = contract["argv"]
    if not isinstance(argv, list) or not argv or any(
        not isinstance(item, str) or not item for item in argv
    ):
        raise BenchError("launch contract argv must be a non-empty string array")
    cwd = resolve_contract_path(contract["working_directory"])
    if not cwd.is_dir():
        raise BenchError(f"launch contract working_directory is not a directory: {cwd}")
    cold_start_prompt = resolve_contract_path(
        contract["cold_start_prompt_path"]
    ).read_text(encoding="utf-8")
    work_instruction_test = resolve_contract_path(
        contract["work_instruction_test_path"]
    ).read_text(encoding="utf-8")
    stdin_text = "\n".join(
        [
            cold_start_prompt.rstrip("\n"),
            "",
            work_instruction_test.rstrip("\n"),
            "",
        ]
    )
    timeout_seconds = int(contract["cutoff_minutes"]) * 60
    started = time.monotonic()
    try:
        completed = subprocess.run(
            argv,
            cwd=cwd,
            env=launch_child_env(),
            input=stdin_text,
            capture_output=True,
            text=True,
            timeout=timeout_seconds,
            check=False,
        )
        duration = time.monotonic() - started
        return {
            "argv": argv,
            "cwd": str(cwd),
            "stdin": stdin_text,
            "stdout": completed.stdout,
            "stderr": completed.stderr,
            "exit_code": completed.returncode,
            "timed_out": False,
            "duration_seconds": round(duration, 3),
            "success": completed.returncode == 0,
        }
    except subprocess.TimeoutExpired as error:
        duration = time.monotonic() - started
        return {
            "argv": argv,
            "cwd": str(cwd),
            "stdin": stdin_text,
            "stdout": timeout_stream(error.stdout),
            "stderr": timeout_stream(error.stderr),
            "exit_code": None,
            "timed_out": True,
            "duration_seconds": round(duration, 3),
            "success": False,
        }
    except OSError as error:
        duration = time.monotonic() - started
        return {
            "argv": argv,
            "cwd": str(cwd),
            "stdin": stdin_text,
            "stdout": "",
            "stderr": f"spawn failed: {error}\n",
            "exit_code": None,
            "timed_out": False,
            "duration_seconds": round(duration, 3),
            "success": False,
        }


def launch_child_env() -> dict[str, str]:
    return {
        key: value
        for key, value in os.environ.items()
        if not key.startswith("MIMIR_")
    }


def timeout_stream(value: str | bytes | None) -> str:
    if value is None:
        return ""
    if isinstance(value, bytes):
        return value.decode("utf-8", errors="replace")
    return value


def resolve_contract_path(path_value: str) -> Path:
    path = Path(path_value).expanduser()
    if path.is_absolute():
        return path
    return REPO_ROOT / path


def execution_transcript(
    scenario: dict[str, Any],
    launch_row: dict[str, Any],
    contract: dict[str, Any],
    execution: dict[str, Any],
) -> str:
    return "\n".join(
        [
            f"# Scenario {scenario['id']} - transcript {launch_row['baseline_id']}",
            "",
            f"Scenario: {scenario['title']}",
            f"Baseline: {launch_row['baseline_id']} - {launch_row['baseline_name']}",
            f"Runner: {contract['runner']}",
            f"Command: {' '.join(contract['argv'])}",
            f"Working directory: {contract['working_directory']}",
            f"Exit code: {execution['exit_code']}",
            f"Timed out: {str(execution['timed_out']).lower()}",
            f"Duration seconds: {execution['duration_seconds']}",
            "",
            "## Cold-start prompt",
            "",
            scenario["cold_start_prompt"],
            "",
            "## Work-instruction test",
            "",
            scenario["work_instruction_test"],
            "",
            "## Captured stdin",
            "",
            fenced_text(execution["stdin"]),
            "",
            "## Captured stdout",
            "",
            fenced_text(execution["stdout"]),
            "",
            "## Captured stderr",
            "",
            fenced_text(execution["stderr"]),
            "",
        ]
    )


def fenced_text(text: str) -> str:
    return "```text\n" + text.rstrip("\n") + "\n```"


def update_mechanical_scores(
    scores: dict[str, Any],
    baseline_id: str,
    scenario: dict[str, Any],
    execution: dict[str, Any],
) -> int:
    baselines = scores["baselines"]
    if baseline_id not in baselines:
        raise BenchError(f"scores.json missing baseline {baseline_id}")
    baseline = baselines[baseline_id]
    require_mapping(baseline, Path("scores.json"), f"baselines.{baseline_id}")
    tokens = baseline.get("rehydration_tokens")
    require_mapping(
        tokens,
        Path("scores.json"),
        f"baselines.{baseline_id}.rehydration_tokens",
    )
    updates = 0
    cutoff_seconds = int(scenario["cutoff_minutes"]) * 60
    if baseline.get("time_to_productive_minutes") is None:
        baseline["time_to_productive_minutes"] = (
            "DNR"
            if execution["timed_out"] or execution["duration_seconds"] > cutoff_seconds
            else int(execution["duration_seconds"] // 60)
        )
        updates += 1
    if tokens.get("input") is None:
        tokens["input"] = estimate_token_count(execution["stdin"])
        updates += 1
    if tokens.get("output") is None:
        tokens["output"] = estimate_token_count(
            execution["stdout"] + "\n" + execution["stderr"]
        )
        updates += 1
    return updates


def estimate_token_count(text: str) -> int:
    stripped = text.strip()
    if not stripped:
        return 0
    return max(1, (len(stripped) + 3) // 4)


def launch_contract_problem(
    contract_path: Path,
    launch_row: dict[str, Any],
    scenario: dict[str, Any],
) -> str | None:
    if not launch_row["ready_for_launch"]:
        return "environment_not_ready"
    if not contract_path.exists():
        return "missing"
    if not contract_path.is_file():
        return "not_file"
    try:
        contract = json.loads(contract_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return "invalid_json"
    if contract != launch_row["launch_contract"]:
        return "stale_or_tampered"
    cold_start_problem = launch_contract_file_content_problem(
        resolve_contract_path(contract["cold_start_prompt_path"]),
        scenario["cold_start_prompt"] + "\n",
        "cold_start_prompt",
    )
    if cold_start_problem is not None:
        return cold_start_problem
    work_instruction_problem = launch_contract_file_content_problem(
        resolve_contract_path(contract["work_instruction_test_path"]),
        scenario["work_instruction_test"] + "\n",
        "work_instruction_test",
    )
    if work_instruction_problem is not None:
        return work_instruction_problem
    return None


def launch_contract_file_content_problem(
    path: Path,
    expected: str,
    label: str,
) -> str | None:
    if not path.exists():
        return f"{label}_missing"
    if not path.is_file():
        return f"{label}_not_file"
    if path.read_text(encoding="utf-8") != expected:
        return f"{label}_stale_or_tampered"
    return None


def launch_blocked_reasons(validation_row: dict[str, Any]) -> list[str]:
    reasons: list[str] = []
    reasons.extend(validation_row["missing_inputs"])
    reasons.extend(
        f"{item['id']}: {item['problem']}"
        for item in validation_row["invalid_inputs"]
    )
    reasons.extend(validation_row["missing_files"])
    return reasons


def launch_contract(
    scenario: dict[str, Any],
    baseline: dict[str, Any],
    result_dir: Path,
) -> dict[str, Any]:
    baseline_id = baseline["id"]
    env_dir = result_dir / "environments" / baseline_id
    inputs_path = env_dir / "materialized-inputs.json"
    preserved_inputs = []
    if inputs_path.is_file():
        inputs = load_materialized_inputs(inputs_path, scenario["id"], baseline_id)
        preserved_inputs = [
            {
                "id": item["id"],
                "kind": item["kind"],
                "path": item.get("path"),
            }
            for item in inputs["inputs"]
            if item.get("required")
        ]
    runner = "mimir_wrapped_claude" if baseline_id == "D" else "native_claude"
    argv = ["mimir", "claude"] if baseline_id == "D" else ["claude"]
    return {
        "schema_version": 1,
        "execution_mode": "manual_contract",
        "live_execution": False,
        "runner": runner,
        "argv": argv,
        "working_directory": display_path(env_dir),
        "cold_start_prompt_path": display_path(env_dir / "cold-start-prompt.txt"),
        "work_instruction_test_path": display_path(
            env_dir / "work-instruction-test.txt"
        ),
        "transcript_path": display_path(result_dir / f"transcript-{baseline_id}.md"),
        "cutoff_minutes": scenario["cutoff_minutes"],
        "preserved_inputs": preserved_inputs,
        "capture_contract": (
            "Record the full terminal transcript into transcript_path, including "
            "the cold-start prompt and work-instruction test."
        ),
    }


def load_materialized_inputs(
    path: Path,
    scenario_id: str,
    baseline_id: str,
) -> dict[str, Any]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise BenchError(f"{path}: invalid JSON: {error}") from error
    require_mapping(data, path, "root")
    if data.get("schema_version") != 1:
        raise BenchError(f"{path}: schema_version must be 1")
    if data.get("scenario_id") != scenario_id:
        raise BenchError(f"{path}: scenario_id must match {scenario_id}")
    if data.get("baseline_id") != baseline_id:
        raise BenchError(f"{path}: baseline_id must match {baseline_id}")
    inputs = data.get("inputs")
    if not isinstance(inputs, list):
        raise BenchError(f"{path}: inputs must be an array")
    for index, item in enumerate(inputs):
        if not isinstance(item, dict):
            raise BenchError(f"{path}: inputs[{index}] must be an object")
        if not isinstance(item.get("id"), str) or not item["id"]:
            raise BenchError(f"{path}: inputs[{index}].id must be a non-empty string")
        for prior in inputs[:index]:
            if isinstance(prior, dict) and prior.get("id") == item["id"]:
                raise BenchError(f"{path}: inputs[{index}].id duplicates {item['id']}")
    return data


def materialized_input_path_problem(item: dict[str, Any]) -> str | None:
    kind = item.get("kind")
    if not isinstance(kind, str) or not kind:
        return "kind must be a non-empty string"
    path_value = item.get("path")
    if not isinstance(path_value, str) or not path_value.strip():
        return "path must be a non-empty string"
    materialized_path = Path(path_value).expanduser()
    if kind == "file":
        return None if materialized_path.is_file() else "expected file"
    if kind == "directory":
        return None if materialized_path.is_dir() else "expected directory"
    if kind == "manual":
        return None if materialized_path.exists() else "expected existing path"
    return f"unknown kind {kind}"


def recovery_summary_results_payload(
    scenarios: list[dict[str, Any]],
    results_root: Path,
) -> dict[str, Any]:
    rows = []
    for scenario in scenarios:
        scores_path = results_root / scenario["id"] / "scores.json"
        transcript_validation = recovery_validate_transcripts_payload(
            scenario,
            results_root,
        )
        transcript_problems = transcript_problem_rows(transcript_validation)
        if not scores_path.is_file():
            rows.append(
                {
                    "scenario_id": scenario["id"],
                    "title": scenario["title"],
                    "score_path": display_path(scores_path),
                    "score_file_present": False,
                    "score_problem": "missing",
                    "complete": False,
                    "missing_count": 0,
                    "missing_fields": [],
                    "transcripts_ready": transcript_validation["ready_for_scoring"],
                    "transcript_problem_count": len(transcript_problems),
                    "transcript_problems": transcript_problems,
                    "baseline_summaries": [],
                }
            )
            continue
        try:
            scores = json.loads(scores_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError as error:
            raise BenchError(f"{scores_path}: invalid JSON: {error}") from error
        missing_fields, summaries = validate_scores(scenario, scores, scores_path)
        complete = not missing_fields and not transcript_problems
        row: dict[str, Any] = {
            "scenario_id": scenario["id"],
            "title": scenario["title"],
            "score_path": display_path(scores_path),
            "score_file_present": True,
            "score_problem": None,
            "complete": complete,
            "missing_count": len(missing_fields),
            "missing_fields": missing_fields,
            "transcripts_ready": transcript_validation["ready_for_scoring"],
            "transcript_problem_count": len(transcript_problems),
            "transcript_problems": transcript_problems,
            "baseline_summaries": summaries if complete else [],
        }
        if complete:
            row["scenario_verdict"] = scenario_verdict(summaries)
        rows.append(row)
    complete_count = sum(1 for row in rows if row["complete"])
    return {
        "mode": "summary_results",
        "live_execution": False,
        "results_root": display_path(results_root),
        "scenario_count": len(rows),
        "complete_count": complete_count,
        "incomplete_count": len(rows) - complete_count,
        "missing_score_file_count": sum(
            1 for row in rows if not row["score_file_present"]
        ),
        "benchmark_verdict": benchmark_verdict(rows),
        "scenarios": rows,
    }


def benchmark_verdict(rows: list[dict[str, Any]]) -> dict[str, Any]:
    complete_rows = [row for row in rows if row["complete"]]
    mimir_wins = sum(
        1 for row in complete_rows if row["scenario_verdict"]["mimir_win"]
    )
    required_wins = required_mimir_wins(len(complete_rows))
    complete = bool(rows) and len(complete_rows) == len(rows)
    return {
        "complete": complete,
        "scenario_count": len(rows),
        "complete_scenarios": len(complete_rows),
        "incomplete_scenarios": len(rows) - len(complete_rows),
        "mimir_wins": mimir_wins,
        "required_wins": required_wins,
        "benchmark_win": complete and mimir_wins >= required_wins,
        "threshold": "Mimir wins at least two thirds of complete scenarios",
    }


def transcript_problem_rows(validation: dict[str, Any]) -> list[dict[str, Any]]:
    return [
        {
            "baseline_id": row["baseline_id"],
            "transcript_path": row["transcript_path"],
            "problem": row["problem"],
        }
        for row in validation["baselines"]
        if not row["captured"]
    ]


def required_mimir_wins(complete_scenarios: int) -> int:
    if complete_scenarios == 0:
        return 0
    return (2 * complete_scenarios + 2) // 3


def scenario_verdict(summaries: list[dict[str, Any]]) -> dict[str, Any]:
    baseline_d = baseline_summary_by_id(summaries, "D")
    baseline_b = baseline_summary_by_id(summaries, "B")
    non_d = [summary for summary in summaries if summary["id"] != "D"]
    if not non_d:
        raise BenchError("summary verdict requires at least one non-D baseline")

    metric_specs = [
        ("time_to_productive_minutes", "lower"),
        ("fact_unprompted_correct_pct", "higher"),
        ("hallucination_rate", "lower"),
        ("stale_occurrences", "lower"),
        ("rehydration_token_total", "lower"),
    ]
    metric_results = [
        scenario_metric_result(baseline_d, non_d, metric, direction)
        for metric, direction in metric_specs
    ]
    d_metric_wins = sum(
        1 for result in metric_results if result["d_beats_best_non_d"]
    )
    guardrails = {
        "hallucinations_not_worse_than_b": baseline_d["hallucination_count"]
        <= baseline_b["hallucination_count"],
        "staleness_better_than_b": baseline_d["stale_occurrences"]
        < baseline_b["stale_occurrences"],
    }
    return {
        "mimir_win": d_metric_wins >= 3 and all(guardrails.values()),
        "d_metric_wins": d_metric_wins,
        "required_metric_wins": 3,
        "guardrails": guardrails,
        "metric_results": metric_results,
    }


def baseline_summary_by_id(
    summaries: list[dict[str, Any]],
    baseline_id: str,
) -> dict[str, Any]:
    for summary in summaries:
        if summary["id"] == baseline_id:
            return summary
    raise BenchError(f"summary verdict requires baseline {baseline_id}")


def scenario_metric_result(
    baseline_d: dict[str, Any],
    non_d: list[dict[str, Any]],
    metric: str,
    direction: str,
) -> dict[str, Any]:
    lower_is_better = direction == "lower"
    best_non_d = sorted(
        non_d,
        key=lambda summary: comparable_metric_value(summary[metric], lower_is_better),
        reverse=not lower_is_better,
    )[0]
    d_value = comparable_metric_value(baseline_d[metric], lower_is_better)
    best_value = comparable_metric_value(best_non_d[metric], lower_is_better)
    d_beats = d_value < best_value if lower_is_better else d_value > best_value
    return {
        "metric": metric,
        "direction": direction,
        "d_value": baseline_d[metric],
        "best_non_d_baseline": best_non_d["id"],
        "best_non_d_value": best_non_d[metric],
        "d_beats_best_non_d": d_beats,
    }


def comparable_metric_value(value: Any, lower_is_better: bool) -> float:
    if value is None:
        return float("inf") if lower_is_better else float("-inf")
    return float(value)


def validate_scores(
    scenario: dict[str, Any],
    scores: Any,
    path: Path,
) -> tuple[list[str], list[dict[str, Any]]]:
    require_mapping(scores, path, "root")
    schema_version = scores.get("schema_version")
    if schema_version != 1:
        raise BenchError(f"{path}: schema_version must be 1")
    if scores.get("scenario_id") != scenario["id"]:
        raise BenchError(f"{path}: scenario_id must match {scenario['id']}")
    baselines = scores.get("baselines")
    require_mapping(baselines, path, "baselines")
    expected_ids = [baseline["id"] for baseline in scenario["baselines"]]
    actual_ids = sorted(str(key) for key in baselines.keys())
    if actual_ids != sorted(expected_ids):
        raise BenchError(
            f"{path}: baselines must contain exactly {', '.join(expected_ids)}"
        )

    missing: list[str] = []
    complete_inputs: list[tuple[str, dict[str, Any]]] = []
    for baseline_id in expected_ids:
        baseline = baselines[baseline_id]
        require_mapping(baseline, path, f"baselines.{baseline_id}")
        normalized = collect_score_inputs(
            scenario,
            baseline,
            f"baselines.{baseline_id}",
            missing,
        )
        if normalized is not None:
            complete_inputs.append((baseline_id, normalized))

    if missing:
        return missing, []
    return [], [
        summarize_baseline_score(scenario, baseline_id, values)
        for baseline_id, values in complete_inputs
    ]


def collect_score_inputs(
    scenario: dict[str, Any],
    baseline: dict[str, Any],
    prefix: str,
    missing: list[str],
) -> dict[str, Any] | None:
    time_value = required_value(baseline, "time_to_productive_minutes", prefix, missing)
    fact = required_mapping_value(baseline, "fact_correctness", prefix)
    correct = required_value(fact, "correct", f"{prefix}.fact_correctness", missing)
    prompted = required_value(fact, "prompted", f"{prefix}.fact_correctness", missing)
    wrong = required_value(fact, "wrong", f"{prefix}.fact_correctness", missing)
    silent = required_value(fact, "silent", f"{prefix}.fact_correctness", missing)
    decisions = required_mapping_value(baseline, "decision_assertions", prefix)
    hallucinations = required_value(
        decisions,
        "hallucinations",
        f"{prefix}.decision_assertions",
        missing,
    )
    decision_total = required_value(
        decisions,
        "total",
        f"{prefix}.decision_assertions",
        missing,
    )
    staleness = required_mapping_value(baseline, "staleness", prefix)
    stale = required_value(
        staleness,
        "stale_occurrences",
        f"{prefix}.staleness",
        missing,
    )
    tokens = required_mapping_value(baseline, "rehydration_tokens", prefix)
    input_tokens = required_value(
        tokens,
        "input",
        f"{prefix}.rehydration_tokens",
        missing,
    )
    output_tokens = required_value(
        tokens,
        "output",
        f"{prefix}.rehydration_tokens",
        missing,
    )

    raw_values = [
        time_value,
        correct,
        prompted,
        wrong,
        silent,
        hallucinations,
        decision_total,
        stale,
        input_tokens,
        output_tokens,
    ]
    if any(value is None for value in raw_values):
        return None

    time_minutes = parse_time_value(time_value, f"{prefix}.time_to_productive_minutes")
    cutoff_minutes = parse_non_negative_int(
        scenario["cutoff_minutes"],
        "scenario.cutoff_minutes",
    )
    if time_minutes is not None and time_minutes > cutoff_minutes:
        raise BenchError(
            f"{prefix}.time_to_productive_minutes exceeds cutoff_minutes "
            f"{cutoff_minutes}; use DNR when recovery misses the scenario cutoff"
        )
    correct_i = parse_non_negative_int(correct, f"{prefix}.fact_correctness.correct")
    prompted_i = parse_non_negative_int(prompted, f"{prefix}.fact_correctness.prompted")
    wrong_i = parse_non_negative_int(wrong, f"{prefix}.fact_correctness.wrong")
    silent_i = parse_non_negative_int(silent, f"{prefix}.fact_correctness.silent")
    hallucinations_i = parse_non_negative_int(
        hallucinations,
        f"{prefix}.decision_assertions.hallucinations",
    )
    decision_total_i = parse_non_negative_int(
        decision_total,
        f"{prefix}.decision_assertions.total",
    )
    if decision_total_i == 0:
        raise BenchError(
            f"{prefix}.decision_assertions.total must be greater than zero"
        )
    stale_i = parse_non_negative_int(stale, f"{prefix}.staleness.stale_occurrences")
    staleness_test_count = len(scenario["staleness_tests"])
    if stale_i > staleness_test_count:
        raise BenchError(
            f"{prefix}.staleness.stale_occurrences exceeds staleness_tests "
            f"{staleness_test_count}"
        )
    input_tokens_i = parse_non_negative_int(
        input_tokens,
        f"{prefix}.rehydration_tokens.input",
    )
    output_tokens_i = parse_non_negative_int(
        output_tokens,
        f"{prefix}.rehydration_tokens.output",
    )
    fact_total = correct_i + prompted_i + wrong_i + silent_i
    expected_total = len(scenario["ground_truth"])
    if fact_total != expected_total:
        raise BenchError(
            f"{prefix}.fact_correctness totals {fact_total}, expected {expected_total}"
        )
    if hallucinations_i > decision_total_i:
        raise BenchError(f"{prefix}.decision_assertions.hallucinations exceeds total")
    return {
        "time_minutes": time_minutes,
        "correct": correct_i,
        "prompted": prompted_i,
        "wrong": wrong_i,
        "silent": silent_i,
        "hallucinations": hallucinations_i,
        "decision_total": decision_total_i,
        "stale": stale_i,
        "input_tokens": input_tokens_i,
        "output_tokens": output_tokens_i,
    }


def required_mapping_value(data: dict[str, Any], field: str, prefix: str) -> dict[str, Any]:
    value = data.get(field)
    if not isinstance(value, dict):
        raise BenchError(f"{prefix}.{field} must be an object")
    return value


def required_value(
    data: dict[str, Any],
    field: str,
    prefix: str,
    missing: list[str],
) -> Any:
    value = data.get(field)
    if value is None:
        missing.append(f"{prefix}.{field}")
    return value


def require_mapping(value: Any, path: Path, label: str) -> None:
    if not isinstance(value, dict):
        raise BenchError(f"{path}: {label} must be an object")


def parse_time_value(value: Any, path: str) -> int | None:
    if value == "DNR":
        return None
    return parse_non_negative_int(value, path)


def parse_non_negative_int(value: Any, path: str) -> int:
    if isinstance(value, bool) or not isinstance(value, int) or value < 0:
        raise BenchError(f"{path} must be a non-negative integer")
    return value


def summarize_baseline_score(
    scenario: dict[str, Any],
    baseline_id: str,
    values: dict[str, Any],
) -> dict[str, Any]:
    fact_count = len(scenario["ground_truth"])
    decision_total = values["decision_total"]
    return {
        "id": baseline_id,
        "did_not_recover": values["time_minutes"] is None,
        "time_to_productive_minutes": values["time_minutes"],
        "fact_unprompted_correct_pct": round(values["correct"] / fact_count, 4),
        "fact_prompted_count": values["prompted"],
        "fact_wrong_count": values["wrong"],
        "fact_silent_count": values["silent"],
        "hallucination_count": values["hallucinations"],
        "hallucination_rate": round(values["hallucinations"] / decision_total, 4)
        if decision_total
        else 0.0,
        "stale_occurrences": values["stale"],
        "rehydration_token_total": values["input_tokens"] + values["output_tokens"],
    }


